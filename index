/* ================= DEIN ORIGINAL CSS ================= */

:root {
  --bg: #F7F5F0;
  --bg2: #EFECEA;
  --white: #FFFFFF;
  --ink: #1A1A18;
  --ink2: #3D3D38;
  --muted: #8C8B84;
  --accent: #2B4C2E;
  --accent2: #4A7C50;
  --accent-light: #E8F0E9;
  --border: #DDDBD4;
  --serif: 'Playfair Display', Georgia, serif;
  --sans: 'DM Sans', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--ink); font-family: var(--sans); font-weight: 300; line-height: 1.6; }

nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 48px;
  background: rgba(247,245,240,0.92);
  border-bottom: 1px solid var(--border);
}

.logo { font-family: var(--serif); font-size: 22px; font-weight: 700; color: var(--accent); text-decoration: none; }

.nav-cta { background: var(--accent); color: white; padding: 10px 24px; text-decoration: none; }

.hero { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; padding-top: 80px; }

.hero-left { padding: 80px; }
.hero-right { background: var(--accent); display:flex; align-items:center; justify-content:center; }

.section { padding: 100px 80px; }

footer {
  background: var(--ink);
  padding: 40px;
  display:flex;
  gap:20px;
  flex-wrap:wrap;
}

.footer-link {
  color: rgba(255,255,255,0.6);
  text-decoration:none;
}

